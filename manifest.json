{
  "manifest_version": 3,
  "name": "newB - 让你的Bilibili焕然一新",
  "short_name": "newB",
  "version": "0.3.0",
  "description": "优化Bilibili使用体验。",
  "default_locale": "zh_CN",
  "author": "ASneka",

  "icons": {
    "128": "assets/icon.png"
  },

  "permissions": ["storage"],

  "host_permissions": ["*://*.bilibili.com/*", "*://api.bilibili.com/*"],

  "action": {
    "default_icon": {
      "128": "assets/icon.png"
    },
    "default_title": "newB",
    "default_popup": "popup/popup.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/bililv.svg"],
      "matches": ["*://*.bilibili.com/*"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/*"],
      "css": [
        "styles/layout/global.css",
        "styles/layout/header.css",
        "styles/layout/home.css",
        "styles/layout/search.css",
        "styles/layout/video.css",
        "styles/hide-home-feed.css",
        "styles/hide-hot-search.css",
        "styles/hide-recommend.css",
        "styles/user-info-hover.css",
        "styles/video-info-hover.css",
        "styles/night-mode.css"
      ],
      "js": [
        "common/bili-api.js",
        "common/config-manager.js",
        "common/utils.js",
        "content/core/ui-engine.js",
        "content/core/main.js",
        "content/modules/cleanup-engine.js",
        "content/modules/cover-viewer.js",
        "content/modules/filter-engine.js",
        "content/modules/user-info-hover.js",
        "content/modules/video-info-hover.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["inject/main-world-patch.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
